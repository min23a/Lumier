{%- comment -%}
  snippets/icon.liquid — Lumière Beauty Theme
  ═══════════════════════════════════════════════════════════
  Inline SVG icon system. Single source of truth for all icons.
  Eliminates duplicated SVG markup scattered across templates.

  PARAMETERS:
    name  {string}  — Icon name (required). See list below.
    size  {number}  — Pixel size for width & height (default: 20)
    class {string}  — Additional CSS classes (optional)
    aria  {string}  — aria-label text. Omit for decorative icons.

  USAGE:
    {%- render 'icon', name: 'cart', size: 24 -%}
    {%- render 'icon', name: 'search', size: 20, class: 'header__icon' -%}
    {%- render 'icon', name: 'star', size: 14, aria: '5 stars' -%}

  AVAILABLE ICONS:
    Navigation:  arrow-left, arrow-right, arrow-up, arrow-down,
                 chevron-left, chevron-right, chevron-up, chevron-down,
                 external, close, menu, back
    Commerce:    cart, cart-plus, bag, tag, credit-card, gift,
                 truck, returns, package, barcode
    User:        user, user-circle, account, logout, key, lock
    Search:      search, filter, sort
    Content:     star, star-filled, heart, heart-filled, bookmark,
                 share, link, copy, eye, zoom, image, video
    Interface:   check, check-circle, plus, minus, x, info, warning,
                 alert, spinner, dots-h, dots-v
    Beauty/Brand: leaf, drop, sun, shield, sparkle, flower, lab
    Social:      instagram, tiktok, pinterest, youtube, facebook, twitter
{%- endcomment -%}

{%- liquid
  unless size > 0; assign size = 20; endunless
  assign icon_class = 'icon icon--' | append: name
  if class != blank
    assign icon_class = icon_class | append: ' ' | append: class
  endif
-%}

<svg
  class="{{ icon_class }}"
  width="{{ size }}"
  height="{{ size }}"
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.75"
  stroke-linecap="round"
  stroke-linejoin="round"
  {%- if aria != blank %}
    role="img"
    aria-label="{{ aria | escape }}"
  {%- else %}
    aria-hidden="true"
    focusable="false"
  {%- endif %}
>
  {%- case name -%}

    {%- comment -%} ── Navigation ────────────────────────────────── {%- endcomment -%}
    {%- when 'arrow-left' -%}
      <path d="M19 12H5M12 5l-7 7 7 7"/>
    {%- when 'arrow-right' -%}
      <path d="M5 12h14M12 5l7 7-7 7"/>
    {%- when 'arrow-up' -%}
      <path d="M12 19V5M5 12l7-7 7 7"/>
    {%- when 'arrow-down' -%}
      <path d="M12 5v14M5 12l7 7 7-7"/>
    {%- when 'chevron-left' -%}
      <path d="M15 18l-6-6 6-6"/>
    {%- when 'chevron-right' -%}
      <path d="M9 18l6-6-6-6"/>
    {%- when 'chevron-up' -%}
      <path d="M18 15l-6-6-6 6"/>
    {%- when 'chevron-down' -%}
      <path d="M6 9l6 6 6-6"/>
    {%- when 'external' -%}
      <path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6M15 3h6v6M10 14L21 3"/>
    {%- when 'close' -%}
      <path d="M18 6L6 18M6 6l12 12"/>
    {%- when 'menu' -%}
      <line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/>
    {%- when 'back' -%}
      <path d="M19 12H5M12 5l-7 7 7 7"/>

    {%- comment -%} ── Commerce ──────────────────────────────────── {%- endcomment -%}
    {%- when 'cart' -%}
      <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/>
    {%- when 'cart-plus' -%}
      <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/><line x1="12" y1="14" x2="12" y2="18"/><line x1="10" y1="16" x2="14" y2="16"/>
    {%- when 'bag' -%}
      <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4zM16 10a4 4 0 01-8 0"/>
    {%- when 'tag' -%}
      <path d="M20.59 13.41l-7.17 7.17a2 2 0 01-2.83 0L2 12V2h10l8.59 8.59a2 2 0 010 2.82zM7 7h.01"/>
    {%- when 'credit-card' -%}
      <rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/>
    {%- when 'gift' -%}
      <polyline points="20 12 20 22 4 22 4 12"/><rect x="2" y="7" width="20" height="5"/><line x1="12" y1="22" x2="12" y2="7"/><path d="M12 7H7.5a2.5 2.5 0 010-5C11 2 12 7 12 7zM12 7h4.5a2.5 2.5 0 000-5C13 2 12 7 12 7z"/>
    {%- when 'truck' -%}
      <rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/>
    {%- when 'returns' -%}
      <path d="M2.5 2v6h6M2.66 15.57a10 10 0 1 0 .57-8.38"/>
    {%- when 'package' -%}
      <line x1="16.5" y1="9.4" x2="7.55" y2="4.24"/><path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 001 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/>

    {%- comment -%} ── User ──────────────────────────────────────── {%- endcomment -%}
    {%- when 'user' -%}
      <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/>
    {%- when 'user-circle' -%}
      <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/><circle cx="12" cy="12" r="10"/>
    {%- when 'account' -%}
