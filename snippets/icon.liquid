      <path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/>
    {%- when 'plus' -%}
      <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
    {%- when 'minus' -%}
      <line x1="5" y1="12" x2="19" y2="12"/>
    {%- when 'x' -%}
      <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
    {%- when 'info' -%}
      <circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/>
    {%- when 'warning' -%}
      <path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0zM12 9v4M12 17h.01"/>
    {%- when 'alert' -%}
      <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
    {%- when 'spinner' -%}
      <line x1="12" y1="2" x2="12" y2="6"/><line x1="12" y1="18" x2="12" y2="22"/><line x1="4.93" y1="4.93" x2="7.76" y2="7.76"/><line x1="16.24" y1="16.24" x2="19.07" y2="19.07"/><line x1="2" y1="12" x2="6" y2="12"/><line x1="18" y1="12" x2="22" y2="12"/><line x1="4.93" y1="19.07" x2="7.76" y2="16.24"/><line x1="16.24" y1="7.76" x2="19.07" y2="4.93"/>
    {%- when 'dots-h' -%}
      <circle cx="12" cy="12" r="1"/><circle cx="19" cy="12" r="1"/><circle cx="5" cy="12" r="1"/>
    {%- when 'dots-v' -%}
      <circle cx="12" cy="12" r="1"/><circle cx="12" cy="5" r="1"/><circle cx="12" cy="19" r="1"/>

    {%- comment -%} ── Beauty / Brand ────────────────────────────── {%- endcomment -%}
    {%- when 'leaf' -%}
      <path d="M17 8C8 10 5.9 16.17 3.82 21.34L5.71 22l1-2.3A4.49 4.49 0 008 20C19 20 22 3 22 3c-1 2-8 2-5 8"/>
    {%- when 'drop' -%}
      <path d="M12 2.69l5.66 5.66a8 8 0 11-11.31 0z"/>
    {%- when 'sun' -%}
      <circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
    {%- when 'shield' -%}
      <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
    {%- when 'sparkle' -%}
      <path d="M12 3l1.5 4.5L18 9l-4.5 1.5L12 15l-1.5-4.5L6 9l4.5-1.5zM20 18l.75 2.25L23 21l-2.25.75L20 24l-.75-2.25L17 21l2.25-.75zM4 3l.75 2.25L7 6l-2.25.75L4 9l-.75-2.25L1 6l2.25-.75z"/>
    {%- when 'flower' -%}
      <circle cx="12" cy="12" r="3"/><path d="M12 2a3 3 0 00-3 3c0 1.65 1.35 3 3 3s3-1.35 3-3a3 3 0 00-3-3zM12 14a3 3 0 00-3 3c0 1.65 1.35 3 3 3s3-1.35 3-3a3 3 0 00-3-3zM2 12a3 3 0 003 3c1.65 0 3-1.35 3-3s-1.35-3-3-3a3 3 0 00-3 3zM14 12a3 3 0 003 3c1.65 0 3-1.35 3-3s-1.35-3-3-3a3 3 0 00-3 3z"/>
    {%- when 'lab' -%}
