{%- comment -%}
  snippets/meta-tags.liquid — Lumière Beauty Theme
  SEO meta tags and Open Graph / Twitter Card markup.
{%- endcomment -%}

{%- liquid
  assign og_title       = page_title
  assign og_description = page_description | default: shop.description | default: shop.name
  assign og_url         = canonical_url
  assign og_type        = 'website'

  if template.name == 'product'
    assign og_type        = 'product'
    assign og_title       = product.title | append: ' – ' | append: shop.name
    assign og_description = product.description | strip_html | truncatewords: 30
    if product.featured_media
      assign og_image = product.featured_media | image_url: width: 1200
    endif
  elsif template.name == 'article'
    assign og_type  = 'article'
    assign og_title = article.title | append: ' – ' | append: shop.name
    if article.image
      assign og_image = article.image | image_url: width: 1200
    endif
  elsif template.name == 'collection'
    assign og_title = collection.title | append: ' – ' | append: shop.name
    if collection.image
      assign og_image = collection.image | image_url: width: 1200
    endif
  endif

  unless og_image
    if settings.og_image
      assign og_image = settings.og_image | image_url: width: 1200
    endif
  endunless
-%}

{%- comment -%} ── Open Graph ─────────────────────────────────────────── {%- endcomment -%}
<meta property="og:site_name"   content="{{ shop.name }}">
<meta property="og:url"         content="{{ og_url }}">
<meta property="og:title"       content="{{ og_title | escape }}">
<meta property="og:type"        content="{{ og_type }}">
<meta property="og:description" content="{{ og_description | escape }}">
{%- if og_image -%}
  <meta property="og:image"     content="https:{{ og_image }}">
  <meta property="og:image:width"  content="1200">
  <meta property="og:image:height" content="630">
{%- endif -%}

{%- comment -%} ── Twitter Card ────────────────────────────────────────── {%- endcomment -%}
<meta name="twitter:card"        content="summary_large_image">
<meta name="twitter:title"       content="{{ og_title | escape }}">
<meta name="twitter:description" content="{{ og_description | escape }}">
{%- if og_image -%}
  <meta name="twitter:image" content="https:{{ og_image }}">
{%- endif -%}

{%- comment -%} ── Product-specific structured data ────────────────────── {%- endcomment -%}
{%- if template.name == 'product' -%}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org/",
    "@type": "Product",
    "name": {{ product.title | json }},
    "url": {{ shop.url | append: product.url | json }},
    "description": {{ product.description | strip_html | json }},
    "brand": {
      "@type": "Brand",
      "name": {{ product.vendor | json }}
    },
    "offers": [
      {%- for variant in product.variants -%}
        {
          "@type": "Offer",
          "priceCurrency": {{ cart.currency.iso_code | json }},
          "price": {{ variant.price | divided_by: 100.0 }},
          "availability": "{% if variant.available %}https://schema.org/InStock{% else %}https://schema.org/OutOfStock{% endif %}",
          "url": {{ shop.url | append: product.url | append: '?variant=' | append: variant.id | json }},
          "sku": {{ variant.sku | json }}
        }{% unless forloop.last %},{% endunless %}
      {%- endfor -%}
    ]
    {%- if product.featured_media -%}
    ,"image": [
      "https:{{ product.featured_media | image_url: width: 1200 }}"
    ]
    {%- endif -%}
  }
  </script>
{%- endif -%}
