{%- comment -%}
  snippets/cart-item.liquid — Lumière Beauty Theme
  Renders a single cart line item inside the drawer and full cart page.
  Used by both SSR (Liquid) and re-rendered by cart.js (innerHTML injection).

  Parameters:
    item  {object}  — cart.items[n]
    index {number}  — forloop.index (1-based)
{%- endcomment -%}

<div
  class="cart-item"
  data-cart-item
  data-item-key="{{ item.key }}"
  data-item-index="{{ index }}"
>
  {%- comment -%} Product image ─────────────────────────────────────── {%- endcomment -%}
  <a
    href="{{ item.url }}"
    class="cart-item__image-wrap"
    aria-hidden="true"
    tabindex="-1"
  >
    {%- if item.image != blank -%}
      <img
        src="{{ item.image | image_url: width: 160 }}"
        srcset="
          {{ item.image | image_url: width: 80  }} 80w,
          {{ item.image | image_url: width: 160 }} 160w
        "
        sizes="80px"
        alt="{{ item.image.alt | default: item.title | escape }}"
        class="cart-item__image"
        width="80"
        height="80"
        loading="lazy"
        decoding="async"
      >
    {%- else -%}
      {{ 'product-1' | placeholder_svg_tag: 'cart-item__image' }}
    {%- endif -%}
  </a>

  {%- comment -%} Info ─────────────────────────────────────────────── {%- endcomment -%}
  <div class="cart-item__info">

    {%- if item.vendor != blank -%}
      <p class="cart-item__vendor">{{ item.vendor | escape }}</p>
    {%- endif -%}

    <p class="cart-item__title">
      <a href="{{ item.url }}">{{- item.product_title | escape -}}</a>
    </p>

    {%- unless item.product.has_only_default_variant -%}
      <p class="cart-item__variant">
        {%- for option in item.options_with_values -%}
          {{- option.name | escape }}: {{ option.value | escape -}}
          {%- unless forloop.last -%} / {%- endunless -%}
        {%- endfor -%}
      </p>
    {%- endunless -%}

    {%- comment -%} Line properties (gift messages, etc.) {%- endcomment -%}
    {%- for property in item.properties -%}
      {%- unless property.first == '_' or property.last == blank -%}
        <p class="cart-item__variant">
          {{ property.first | escape }}: {{ property.last | escape }}
        </p>
      {%- endunless -%}
    {%- endfor -%}

    {%- comment -%} Quantity controls ─────────────────────────────── {%- endcomment -%}
    <div class="cart-item__controls">
      <div class="cart-item__qty" role="group" aria-label="{{ 'products.product.quantity' | t }}">
        <button
          type="button"
          class="cart-item__qty-btn"
          data-qty-btn
          data-direction="minus"
          data-key="{{ item.key }}"
          aria-label="{{ 'accessibility.previous' | t }}"
        >−</button>
        <input
          type="number"
          class="cart-item__qty-input"
          data-qty-input
          data-key="{{ item.key }}"
          value="{{ item.quantity }}"
          min="0"
          max="{{ item.variant.inventory_quantity | default: 99 }}"
          aria-label="{{ 'products.product.quantity' | t }}"
        >
        <button
          type="button"
          class="cart-item__qty-btn"
          data-qty-btn
          data-direction="plus"
          data-key="{{ item.key }}"
          aria-label="{{ 'accessibility.next' | t }}"
        >+</button>
      </div>

      <button
        type="button"
        class="cart-item__remove"
        data-remove-item
        data-key="{{ item.key }}"
        aria-label="{{ 'sections.cart.remove' | t | default: 'Remove' }} {{ item.product_title | escape }}"
      >
        {{- 'sections.cart.remove' | t | default: 'Remove' -}}
      </button>
    </div>

  </div>{%- comment -%} .cart-item__info {%- endcomment -%}

  {%- comment -%} Price ─────────────────────────────────────────────── {%- endcomment -%}
  <div class="cart-item__price-wrap">
    {%- if item.original_line_price != item.final_line_price -%}
      <span class="cart-item__price cart-item__price--sale">
        {{- item.final_line_price | money -}}
      </span>
      <span class="cart-item__compare-price" aria-label="{{ 'products.product.regular_price' | t }}">
        {{- item.original_line_price | money -}}
      </span>
    {%- else -%}
      <span class="cart-item__price">
        {{- item.final_line_price | money -}}
      </span>
    {%- endif -%}
  </div>

</div>{%- comment -%} .cart-item {%- endcomment -%}
