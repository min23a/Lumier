{%- comment -%}
  sections/product-template.liquid — Lumière Beauty Theme
  Full-featured product page section.

  Blocks (all independently orderable/toggleable):
    vendor            — Brand name with link
    title             — Product H1
    price             — Price, compare-at, sale badge
    rating            — Star rating (metafield-driven)
    short_description — Summary paragraph (metafield or first 200 chars)
    variant_picker    — Button / swatch / select pickers per option
    quantity          — Qty stepper
    atc_button        — Add to Cart + dynamic checkout
    trust_bar         — Icon + label trust signals
    collapsible_tab   — Accordion (description, richtext, or metafield)
    share             — Share strip (native + social + copy)
    spacer            — Configurable gap

  Performance:
    • LCP image: fetchpriority="high", loading="eager", full srcset
    • Non-featured images: loading="lazy"
    • Critical CSS inlined via {% style %}
    • Non-critical CSS loaded async
    • JS loaded async with defer
    • Variant JSON embedded inline (no AJAX on first paint)
{%- endcomment -%}

{%- comment -%} ── Critical CSS ──────────────────────────────────────── {%- endcomment -%}
{% style %}
  #shopify-section-{{ section.id }} .product-template {
    padding-top:    {{ section.settings.section_padding_top | default: 48 }}px;
    padding-bottom: {{ section.settings.section_padding_bottom | default: 64 }}px;
  }
{% endstyle %}

{%- comment -%} ── Non-critical CSS (async) ──────────────────────────── {%- endcomment -%}
{{
  'section-product.css'
  | asset_url
  | stylesheet_tag: preload: true, media: 'print', onload: "this.media='all'"
}}

{%- liquid
  assign current_variant   = product.selected_or_first_available_variant
  assign featured_image    = current_variant.featured_media | default: product.featured_media
  assign show_breadcrumb   = section.settings.show_breadcrumb
  assign enable_zoom       = section.settings.enable_zoom
  assign gallery_layout    = section.settings.gallery_layout | default: 'thumbnails'
  assign sticky_atc        = section.settings.sticky_atc
  assign product_form_id   = 'ProductForm-' | append: section.id
-%}

<div class="product-template">

  {%- comment -%} ── Breadcrumb ─────────────────────────────────────── {%- endcomment -%}
  {%- if show_breadcrumb -%}
    <nav class="product-breadcrumb" aria-label="{{ 'accessibility.breadcrumb' | t | default: 'Breadcrumb' }}">
      <a href="{{ routes.root_url }}" class="product-breadcrumb__link">
        {{- 'general.breadcrumb.home' | t | default: 'Home' -}}
      </a>
      <span class="product-breadcrumb__sep" aria-hidden="true">›</span>
      {%- if collection -%}
        <a href="{{ collection.url }}" class="product-breadcrumb__link">
          {{- collection.title | escape -}}
        </a>
        <span class="product-breadcrumb__sep" aria-hidden="true">›</span>
      {%- endif -%}
      <span class="product-breadcrumb__current" aria-current="page">
        {{- product.title | escape -}}
      </span>
    </nav>
  {%- endif -%}

  {%- comment -%} ── Main two-column wrapper ────────────────────────── {%- endcomment -%}
  <div
    class="product-template__wrapper"
    data-product-page
    data-variants="{{ product.variants | json | escape }}"
    data-current-variant="{{ current_variant | json | escape }}"
  >

    {%- comment -%} ══════════════════ GALLERY COLUMN ══════════════════ {%- endcomment -%}
    <div class="product-gallery" data-product-gallery>

      {%- comment -%} ── Main image viewport ─────────────────────────── {%- endcomment -%}
      <div
        class="product-gallery__main"
        data-gallery-main
        aria-label="{{ 'sections.product.gallery' | t | default: 'Product images' }}"
        tabindex="0"
        role="region"
      >
        {%- for media in product.media -%}
          <div
            class="product-gallery__main-slide{% if forloop.first %} is-active{% endif %}"
            data-gallery-slide
            data-media-id="{{ media.id }}"
            data-media-type="{{ media.media_type }}"
          >
            {%- case media.media_type -%}

              {%- when 'image' -%}
                <img
                  src="{{ media | image_url: width: 800 }}"
                  srcset="
                    {{ media | image_url: width: 400  }} 400w,
                    {{ media | image_url: width: 600  }} 600w,
                    {{ media | image_url: width: 800  }} 800w,
                    {{ media | image_url: width: 1200 }} 1200w,
                    {{ media | image_url: width: 1600 }} 1600w
                  "
                  sizes="(max-width: 900px) 100vw, 50vw"
                  alt="{{ media.alt | default: product.title | escape }}"
                  class="product-gallery__main-img"
                  width="{{ media.preview_image.width }}"
                  height="{{ media.preview_image.height }}"
                  {% if forloop.first %}
                    fetchpriority="high"
                    loading="eager"
                    decoding="sync"
                  {% else %}
                    loading="lazy"
                    decoding="async"
                  {% endif %}
                >

              {%- when 'video' -%}
                {{
                  media
                  | video_tag:
                    image_size: '800x',
                    autoplay: section.settings.enable_video_autoplay,
                    loop: true,
                    muted: true,
                    controls: true,
                    class: 'product-gallery__main-img'
                }}

              {%- when 'model' -%}
                {{- media | model_viewer_tag: image_size: '800x', reveal: 'interaction', toggleable: true -}}

              {%- when 'external_video' -%}
                {{- media | external_video_tag: class: 'product-gallery__main-img' -}}

            {%- endcase -%}
          </div>
        {%- endfor -%}

        {%- comment -%} Sale badge ──────────────────────────────────── {%- endcomment -%}
        <div class="product-gallery__badge">
          {%- if current_variant.compare_at_price > current_variant.price -%}
            {%- assign discount_pct = current_variant.compare_at_price
              | minus: current_variant.price
              | times: 100
              | divided_by: current_variant.compare_at_price
              | round -%}
            <span class="badge badge--accent">-{{ discount_pct }}%</span>
          {%- endif -%}
          {%- if product.tags contains 'new' or product.tags contains 'New' -%}
            <span class="badge badge--glass">{{ 'sections.product.new_badge' | t }}</span>
          {%- endif -%}
        </div>

        {%- comment -%} Zoom button ─────────────────────────────────── {%- endcomment -%}
        {%- if enable_zoom and product.media.size > 0 -%}
          <button
            type="button"
            class="product-gallery__zoom-btn"
            data-zoom-open
            aria-label="{{ 'sections.product.zoom' | t }}"
          >
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <circle cx="11" cy="11" r="8"/>
              <line x1="21" y1="21" x2="16.65" y2="16.65"/>
              <line x1="11" y1="8" x2="11" y2="14"/>
              <line x1="8" y1="11" x2="14" y2="11"/>
            </svg>
          </button>
        {%- endif -%}
      </div>

      {%- comment -%} ── Thumbnails ────────────────────────────────── {%- endcomment -%}
      {%- if product.media.size > 1 and gallery_layout == 'thumbnails' -%}
        <div
          class="product-gallery__thumbs"
          role="list"
          aria-label="{{ 'sections.product.gallery_thumbnails' | t | default: 'Product image thumbnails' }}"
        >
          {%- for media in product.media -%}
            <button
              type="button"
              class="product-gallery__thumb{% if forloop.first %} is-active{% endif %}{% if media.media_type == 'video' or media.media_type == 'external_video' %} product-gallery__thumb--video{% endif %}"
              data-gallery-thumb
              role="listitem"
              aria-selected="{{ forloop.first }}"
              aria-label="{{ 'sections.product.gallery_image' | t: number: forloop.index | default: 'Image ' | append: forloop.index }}"
            >
              <img
                src="{{ media.preview_image | image_url: width: 128 }}"
                srcset="
                  {{ media.preview_image | image_url: width: 64  }} 64w,
                  {{ media.preview_image | image_url: width: 128 }} 128w
                "
                sizes="64px"
                alt="{{ media.alt | default: product.title | escape }}"
                class="product-gallery__thumb-img"
                width="64"
                height="64"
                loading="lazy"
                decoding="async"
              >
            </button>
          {%- endfor -%}
        </div>
      {%- endif -%}

    </div>{%- comment -%} .product-gallery {%- endcomment -%}

    {%- comment -%} ══════════════════ INFO COLUMN ══════════════════════ {%- endcomment -%}
    <div class="product-info">

      {%- comment -%} ── ATC form (wraps blocks that need form context) {%- endcomment -%}
      <form
        id="{{ product_form_id }}"
        action="{{ routes.cart_add_url }}"
        method="post"
        enctype="multipart/form-data"
        novalidate
        data-product-form
        data-product-id="{{ product.id }}"
      >
        <input type="hidden" name="id" value="{{ current_variant.id }}">
        <input type="hidden" name="quantity" value="1" data-product-qty-hidden>

        {%- comment -%} ── Render blocks in merchant-defined order ─── {%- endcomment -%}
        {%- for block in section.blocks -%}
          {%- case block.type -%}

            {%- comment -%} ── Vendor ──────────────────────────────── {%- endcomment -%}
            {%- when 'vendor' -%}
              {%- if product.vendor != blank -%}
                <p class="product-vendor" {{ block.shopify_attributes }}>
                  <a href="{{ product.vendor | url_for_vendor }}">
                    {{- product.vendor | escape -}}
                  </a>
                </p>
              {%- endif -%}

            {%- comment -%} ── Title ───────────────────────────────── {%- endcomment -%}
            {%- when 'title' -%}
              <h1 class="product-title" {{ block.shopify_attributes }}>
                {{- product.title | escape -}}
              </h1>

            {%- comment -%} ── Rating ──────────────────────────────── {%- endcomment -%}
            {%- when 'rating' -%}
              {%- if block.settings.show_rating -%}
                {%- assign rating_value = product.metafields.reviews.rating.value -%}
                {%- assign rating_count = product.metafields.reviews.rating_count.value -%}
                {%- if rating_value != blank -%}
                  <div class="product-rating" {{ block.shopify_attributes }}>
                    <div class="product-rating__stars" aria-hidden="true">
                      {%- for i in (1..5) -%}
                        <svg class="product-rating__star{% if i > rating_value %} product-rating__star--empty{% endif %}" viewBox="0 0 14 14" fill="currentColor">
                          <path d="M7 0l1.76 3.56 3.93.57-2.85 2.77.67 3.92L7 8.9l-3.51 1.85.67-3.92L1.31 4.13l3.93-.57z"/>
                        </svg>
                      {%- endfor -%}
                    </div>
                    {%- if rating_count -%}
                      <a href="#ProductReviews" class="product-rating__count">
                        {{- rating_count }} {{ 'sections.product.reviews' | t -}}
                      </a>
                    {%- endif -%}
                  </div>
                {%- endif -%}
              {%- endif -%}

            {%- comment -%} ── Price ───────────────────────────────── {%- endcomment -%}
            {%- when 'price' -%}
              <div class="product-price" {{ block.shopify_attributes }}>
                <span
                  class="product-price__current{% if current_variant.compare_at_price > current_variant.price %} product-price__current--sale{% endif %}"
                  data-product-price
                >
                  {{- current_variant.price | money -}}
                </span>
                {%- if current_variant.compare_at_price > current_variant.price -%}
                  <span class="product-price__compare" data-product-compare-price>
                    {{- current_variant.compare_at_price | money -}}
                  </span>
                  {%- assign discount_pct = current_variant.compare_at_price
                    | minus: current_variant.price
                    | times: 100
                    | divided_by: current_variant.compare_at_price
                    | round -%}
                  <span class="product-price__badge" data-product-price-badge>
                    -{{ discount_pct }}%
                  </span>
                {%- endif -%}
                {%- if product.selected_or_first_available_variant.unit_price_measurement -%}
                  <span class="product-price__unit">
                    {{ current_variant.unit_price | money }} /
                    {%- if current_variant.unit_price_measurement.reference_value != 1 -%}
                      {{ current_variant.unit_price_measurement.reference_value }}
                    {%- endif -%}
                    {{ current_variant.unit_price_measurement.reference_unit }}
                  </span>
                {%- endif -%}
              </div>

            {%- comment -%} ── Short description ───────────────────── {%- endcomment -%}
            {%- when 'short_description' -%}
              {%- liquid
                assign short_desc = product.metafields.custom.short_description.value
                if short_desc == blank
                  assign short_desc = product.description | strip_html | truncate: 220
                endif
              -%}
              {%- if short_desc != blank -%}
                <div class="product-short-desc" {{ block.shopify_attributes }}>
                  {{ short_desc }}
                </div>
              {%- endif -%}

            {%- comment -%} ── Variant picker ──────────────────────── {%- endcomment -%}
            {%- when 'variant_picker' -%}
              {%- unless product.has_only_default_variant -%}
                <div class="product-variant-picker" data-variant-picker {{ block.shopify_attributes }}>
                  {%- for option in product.options_with_values -%}
                    {%- liquid
                      assign picker_type = block.settings.picker_type | default: 'button'
                      assign is_color    = false
                      assign option_name_lower = option.name | downcase
                      if option_name_lower == 'color' or option_name_lower == 'colour' or option_name_lower == 'shade'
                        assign is_color = true
                        if block.settings.color_style == 'swatch'
                          assign picker_type = 'swatch'
                        endif
                      endif
                    -%}
                    <div class="product-option">
                      <label class="product-option__label" id="Option-{{ section.id }}-{{ forloop.index }}">
                        {{ option.name | escape }}
                        {%- if picker_type == 'button' or picker_type == 'swatch' -%}
                          <span class="product-option__selected-val" data-option-value="{{ forloop.index }}">
                            {{- option.selected_value | escape -}}
                          </span>
                        {%- endif -%}
                      </label>

                      {%- case picker_type -%}
                        {%- when 'button' -%}
                          <div class="product-option__buttons" role="group" aria-labelledby="Option-{{ section.id }}-{{ forloop.index }}">
                            {%- for value in option.values -%}
                              {%- liquid
                                assign is_selected  = false
                                assign is_available = false
                                if option.selected_value == value
                                  assign is_selected = true
                                endif
                                for variant in product.variants
                                  if variant.option1 == value or variant.option2 == value or variant.option3 == value
                                    if variant.available
                                      assign is_available = true
                                    endif
                                  endif
                                endfor
                              -%}
                              <button
                                type="button"
                                class="product-option__btn{% if is_selected %} is-selected{% endif %}"
                                data-option-btn
                                data-position="{{ option.position }}"
                                data-value="{{ value | escape }}"
                                {% unless is_available %}disabled{% endunless %}
                                aria-pressed="{{ is_selected }}"
                                aria-label="{{ value | escape }}{% unless is_available %} — {{ 'sections.product.sold_out' | t }}{% endunless %}"
                              >
                                {{- value | escape -}}
                              </button>
                            {%- endfor -%}
                          </div>

                        {%- when 'swatch' -%}
                          <div class="product-option__buttons" role="group" aria-labelledby="Option-{{ section.id }}-{{ forloop.index }}">
                            {%- for value in option.values -%}
                              {%- assign swatch_color = value | handle | replace: '-', '' -%}
                              <button
                                type="button"
                                class="product-option__swatch{% if option.selected_value == value %} is-selected{% endif %}"
                                style="background-color: {{ swatch_color }};"
                                data-option-btn
                                data-position="{{ option.position }}"
                                data-value="{{ value | escape }}"
                                aria-pressed="{{ option.selected_value == value }}"
                                aria-label="{{ value | escape }}"
                                title="{{ value | escape }}"
                              ></button>
                            {%- endfor -%}
                          </div>

                        {%- when 'select' -%}
                          <select
                            class="product-option__select"
                            data-option-select
                            data-position="{{ option.position }}"
                            aria-labelledby="Option-{{ section.id }}-{{ forloop.index }}"
                          >
                            {%- for value in option.values -%}
                              <option
                                value="{{ value | escape }}"
                                {% if option.selected_value == value %}selected{% endif %}
                              >
                                {{- value | escape -}}
                              </option>
                            {%- endfor -%}
                          </select>
                      {%- endcase -%}
                    </div>
                  {%- endfor -%}
                </div>
              {%- endunless -%}

            {%- comment -%} ── Quantity ────────────────────────────── {%- endcomment -%}
            {%- when 'quantity' -%}
              <div class="product-quantity" {{ block.shopify_attributes }}>
                <span class="product-quantity__label" id="QuantityLabel-{{ section.id }}">
                  {{- 'sections.product.quantity' | t -}}
                </span>
                <div class="product-quantity__stepper" role="group" aria-labelledby="QuantityLabel-{{ section.id }}">
                  <button
                    type="button"
                    class="product-quantity__btn"
                    data-qty-decrease
                    aria-label="{{ 'accessibility.previous' | t }}"
                  >−</button>
                  <input
                    type="number"
                    name="quantity"
                    class="product-quantity__input"
                    value="1"
                    min="1"
                    aria-label="{{ 'sections.product.quantity' | t }}"
                    data-product-qty
                    form="{{ product_form_id }}"
                  >
                  <button
                    type="button"
                    class="product-quantity__btn"
                    data-qty-increase
                    aria-label="{{ 'accessibility.next' | t }}"
                  >+</button>
                </div>
              </div>

            {%- comment -%} ── ATC button ──────────────────────────── {%- endcomment -%}
            {%- when 'atc_button' -%}
              <div class="product-atc" {{ block.shopify_attributes }}>
                <button
                  type="submit"
                  name="add"
                  class="product-atc__btn"
                  data-atc-btn
                  form="{{ product_form_id }}"
                  {% unless current_variant.available %}disabled{% endunless %}
                  aria-label="{{ 'sections.product.add_to_cart' | t }}"
                >
                  {%- if current_variant.available -%}
                    {{- 'sections.product.add_to_cart' | t -}}
                  {%- else -%}
                    {{- 'sections.product.sold_out' | t -}}
                  {%- endif -%}
                </button>

                {%- if block.settings.show_dynamic_checkout -%}
                  {{ form | payment_button }}
                {%- endif -%}
              </div>

            {%- comment -%} ── Trust bar ───────────────────────────── {%- endcomment -%}
            {%- when 'trust_bar' -%}
              <div class="product-trust" {{ block.shopify_attributes }}>
                {%- for i in (1..4) -%}
                  {%- assign badge_key = 'badge_' | append: i -%}
                  {%- if block.settings[badge_key] != blank -%}
                    <div class="product-trust__item">
                      <svg viewBox="0 0 16 16" aria-hidden="true">
                        <path d="M8 1l1.4 2.84 3.13.46-2.27 2.21.54 3.13L8 8.22l-2.8 1.42.54-3.13L3.47 4.3l3.13-.46z"/>
                      </svg>
                      {{- block.settings[badge_key] | escape -}}
                    </div>
                  {%- endif -%}
                {%- endfor -%}
              </div>

            {%- comment -%} ── Collapsible tab ─────────────────────── {%- endcomment -%}
            {%- when 'collapsible_tab' -%}
              {%- liquid
                assign tab_content = nil
                case block.settings.content_type
                  when 'description'
                    assign tab_content = product.description
                  when 'richtext'
                    assign tab_content = block.settings.richtext
                  when 'metafield'
                    assign mf_parts = block.settings.metafield_key | split: '.'
                    if mf_parts.size == 3
                      assign tab_content = product.metafields[mf_parts[1]][mf_parts[2]].value
                    endif
                endcase
              -%}
              {%- if block.settings.heading != blank or tab_content != blank -%}
                <div
                  class="product-tab{% if block.settings.open_by_default %} product-tab--open{% endif %}"
                  data-tab
                  {{ block.shopify_attributes }}
                >
                  <button
                    type="button"
                    class="product-tab__trigger"
                    data-tab-trigger
                    aria-expanded="{{ block.settings.open_by_default }}"
                    aria-controls="Tab-{{ block.id }}"
                  >
                    {{- block.settings.heading | default: 'Details' | escape -}}
                    <svg class="product-tab__icon" viewBox="0 0 18 18" aria-hidden="true">
                      <path d="M4 7l5 5 5-5" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </button>
                  <div class="product-tab__body" id="Tab-{{ block.id }}" role="region">
                    <div class="product-tab__content">
                      {{- tab_content -}}
                    </div>
                  </div>
                </div>
              {%- endif -%}

            {%- comment -%} ── Share ────────────────────────────────── {%- endcomment -%}
            {%- when 'share' -%}
              <div class="product-share" data-product-share {{ block.shopify_attributes }}>
                <span class="product-share__label">{{ 'sections.product.share' | t }}</span>
                {%- if navigator.share -%}
                  <button type="button" class="product-share__btn" data-share-btn="native" aria-label="Share">
                    <svg viewBox="0 0 24 24"><path d="M4 12v8a2 2 0 002 2h12a2 2 0 002-2v-8M16 6l-4-4-4 4M12 2v13"/></svg>
                  </button>
                {%- endif -%}
                <button type="button" class="product-share__btn" data-share-btn="twitter" aria-label="Share on X / Twitter">
                  <svg viewBox="0 0 24 24" fill="currentColor" stroke="none"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                </button>
                <button type="button" class="product-share__btn" data-share-btn="facebook" aria-label="Share on Facebook">
                  <svg viewBox="0 0 24 24"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>
                </button>
                <button type="button" class="product-share__btn" data-share-btn="pinterest" aria-label="Pin on Pinterest">
                  <svg viewBox="0 0 24 24" fill="currentColor" stroke="none"><path d="M12 2C6.48 2 2 6.48 2 12c0 4.24 2.65 7.86 6.39 9.29-.09-.78-.17-1.98.03-2.83.19-.77 1.26-5.33 1.26-5.33s-.32-.64-.32-1.59c0-1.49.87-2.61 1.94-2.61.92 0 1.36.69 1.36 1.52 0 .92-.59 2.31-.89 3.59-.25 1.07.53 1.94 1.58 1.94 1.9 0 3.17-2.44 3.17-5.33 0-2.2-1.49-3.74-3.62-3.74-2.47 0-3.92 1.85-3.92 3.77 0 .75.29 1.55.65 1.98.07.09.08.17.06.26-.07.27-.22.87-.25 1-.04.16-.13.2-.3.12-1.13-.52-1.83-2.18-1.83-3.5 0-2.85 2.07-5.47 5.97-5.47 3.14 0 5.58 2.23 5.58 5.22 0 3.11-1.96 5.61-4.68 5.61-.91 0-1.77-.47-2.07-1.03l-.56 2.1c-.2.78-.75 1.76-1.12 2.36.85.26 1.75.4 2.68.4 5.52 0 10-4.48 10-10S17.52 2 12 2z"/></svg>
                </button>
                <button type="button" class="product-share__btn" data-share-btn="copy" aria-label="{{ 'sections.product.copy_link' | t | default: 'Copy link' }}">
                  <svg viewBox="0 0 24 24"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
                </button>
              </div>

            {%- comment -%} ── Spacer ───────────────────────────────── {%- endcomment -%}
            {%- when 'spacer' -%}
              <div
                style="height:{{ block.settings.height | default: 16 }}px;"
                aria-hidden="true"
                {{ block.shopify_attributes }}
              ></div>

          {%- endcase -%}
        {%- endfor -%}

      </form>{%- comment -%} #ProductForm {%- endcomment -%}

      {%- comment -%} ── Collapsible tabs outside the form ──────────── {%- endcomment -%}
      <div class="product-info__tabs" data-product-tabs></div>

    </div>{%- comment -%} .product-info {%- endcomment -%}
  </div>{%- comment -%} .product-template__wrapper {%- endcomment -%}

</div>{%- comment -%} .product-template {%- endcomment -%}

{%- comment -%} ── Zoom lightbox (outside flow) ──────────────────────── {%- endcomment -%}
{%- if enable_zoom -%}
  <div
    class="product-zoom"
    id="ProductZoom"
    role="dialog"
    aria-modal="true"
    aria-label="{{ 'sections.product.zoom' | t }}"
    aria-hidden="true"
  >
    <img src="" alt="" class="product-zoom__img" data-zoom-img draggable="false">
    <button type="button" class="product-zoom__close" data-zoom-close aria-label="{{ 'accessibility.close' | t }}">
      <svg viewBox="0 0 20 20" aria-hidden="true"><path d="M15 5L5 15M5 5l10 10" stroke-linecap="round"/></svg>
    </button>
  </div>
{%- endif -%}

{%- comment -%} ── Sticky ATC bar ─────────────────────────────────────── {%- endcomment -%}
{%- if section.settings.sticky_atc -%}
  <div class="sticky-atc-bar" id="StickyATCBar" aria-hidden="true">
    <div class="sticky-atc-bar__info">
      <div class="sticky-atc-bar__title">{{- product.title | truncate: 40 | escape -}}</div>
      <div class="sticky-atc-bar__price" data-sticky-price>
        {{- current_variant.price | money -}}
      </div>
    </div>
    <button
      type="button"
      class="sticky-atc-bar__btn"
      data-sticky-atc-btn
      {% unless current_variant.available %}disabled{% endunless %}
    >
      {%- if current_variant.available -%}
        {{- 'sections.product.add_to_cart' | t -}}
      {%- else -%}
        {{- 'sections.product.sold_out' | t -}}
      {%- endif -%}
    </button>
  </div>
{%- endif -%}

<script src="{{ 'product.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Product",
  "tag": "section",
  "class": "section-product",
  "settings": [
    {
      "type": "header",
      "content": "Gallery"
    },
    {
      "type": "select",
      "id": "gallery_layout",
      "label": "Thumbnail layout",
      "default": "thumbnails",
      "options": [
        { "value": "thumbnails", "label": "Thumbnails below" },
        { "value": "scrollable", "label": "Scrollable column" }
      ]
    },
    {
      "type": "checkbox",
      "id": "enable_zoom",
      "label": "Enable image zoom lightbox",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_video_autoplay",
      "label": "Autoplay product videos",
      "default": false
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "checkbox",
      "id": "show_breadcrumb",
      "label": "Show breadcrumb",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "sticky_atc",
      "label": "Sticky Add to Cart bar",
      "default": true
    },
    {
      "type": "range",
      "id": "section_padding_top",
      "label": "Padding top",
      "min": 0, "max": 120, "step": 8, "unit": "px", "default": 48
    },
    {
      "type": "range",
      "id": "section_padding_bottom",
      "label": "Padding bottom",
      "min": 0, "max": 120, "step": 8, "unit": "px", "default": 64
    }
  ],
  "blocks": [
    {
      "type": "vendor",
      "name": "Vendor / Brand",
      "limit": 1,
      "settings": []
    },
    {
      "type": "title",
      "name": "Product title",
      "limit": 1,
      "settings": []
    },
    {
      "type": "price",
      "name": "Price",
      "limit": 1,
      "settings": []
    },
    {
      "type": "rating",
      "name": "Star rating",
      "limit": 1,
      "settings": [
        {
          "type": "checkbox",
          "id": "show_rating",
          "label": "Show rating",
          "default": true,
          "info": "Requires metafield: reviews.rating (Rating) and reviews.rating_count (Number)"
        }
      ]
    },
    {
      "type": "short_description",
      "name": "Short description",
      "limit": 1,
      "settings": []
    },
    {
      "type": "variant_picker",
      "name": "Variant picker",
      "limit": 1,
      "settings": [
        {
          "type": "select",
          "id": "picker_type",
          "label": "Default picker type",
          "default": "button",
          "options": [
            { "value": "button", "label": "Buttons" },
            { "value": "select", "label": "Dropdown" }
          ]
        },
        {
          "type": "select",
          "id": "color_style",
          "label": "Colour option style",
          "default": "button",
          "options": [
            { "value": "button", "label": "Text buttons" },
            { "value": "swatch", "label": "Colour swatches" }
          ]
        }
      ]
    },
    {
      "type": "quantity",
      "name": "Quantity selector",
      "limit": 1,
      "settings": []
    },
    {
      "type": "atc_button",
      "name": "Add to cart",
      "limit": 1,
      "settings": [
        {
          "type": "checkbox",
          "id": "show_dynamic_checkout",
          "label": "Show dynamic checkout buttons",
          "default": true,
          "info": "Displays Shop Pay, Apple Pay, etc. based on your enabled payment methods."
        }
      ]
    },
    {
      "type": "trust_bar",
      "name": "Trust signals",
      "limit": 1,
      "settings": [
        { "type": "text", "id": "badge_1", "label": "Badge 1", "default": "Free Shipping $75+" },
        { "type": "text", "id": "badge_2", "label": "Badge 2", "default": "Free Returns" },
        { "type": "text", "id": "badge_3", "label": "Badge 3", "default": "Clean Beauty" },
        { "type": "text", "id": "badge_4", "label": "Badge 4", "default": "Cruelty-Free" }
      ]
    },
    {
      "type": "collapsible_tab",
      "name": "Collapsible tab",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Description"
        },
        {
          "type": "select",
          "id": "content_type",
          "label": "Content source",
          "default": "description",
          "options": [
            { "value": "description", "label": "Product description" },
            { "value": "richtext",    "label": "Custom richtext" },
            { "value": "metafield",   "label": "Metafield" }
          ]
        },
        {
          "type": "richtext",
          "id": "richtext",
          "label": "Custom richtext (if selected above)"
        },
        {
          "type": "text",
          "id": "metafield_key",
          "label": "Metafield key",
          "info": "Format: namespace.key e.g. custom.ingredients",
          "default": "custom.ingredients"
        },
        {
          "type": "checkbox",
          "id": "open_by_default",
          "label": "Open by default",
          "default": false
        }
      ]
    },
    {
      "type": "share",
      "name": "Share",
      "limit": 1,
      "settings": []
    },
    {
      "type": "spacer",
      "name": "Spacer",
      "settings": [
        {
          "type": "range",
          "id": "height",
          "label": "Height",
          "min": 4, "max": 80, "step": 4, "unit": "px", "default": 16
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product — Standard",
      "blocks": [
        { "type": "vendor" },
        { "type": "title" },
        { "type": "price" },
        { "type": "rating" },
        { "type": "short_description" },
        { "type": "variant_picker" },
        { "type": "quantity" },
        { "type": "atc_button" },
        { "type": "trust_bar" },
        { "type": "collapsible_tab", "settings": { "heading": "Description", "content_type": "description", "open_by_default": true } },
        { "type": "collapsible_tab", "settings": { "heading": "Ingredients", "content_type": "metafield", "metafield_key": "custom.ingredients" } },
        { "type": "collapsible_tab", "settings": { "heading": "How to Use",  "content_type": "metafield", "metafield_key": "custom.how_to_use" } },
        { "type": "share" }
      ]
    }
  ]
}
{% endschema %}
