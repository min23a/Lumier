{%- comment -%}
  sections/testimonials.liquid — Lumière Beauty Theme
  Customer testimonials with glassmorphism cards, hero quote,
  aggregate rating, and scroll-snap carousel.

  Blocks:
    heading         — Section title, eyebrow, subtitle
    aggregate_rating — Overall score + count display
    featured_review — Large hero quote card (limit 1)
    review          — Standard testimonial card
    spacer          — Gap control
{%- endcomment -%}

{% style %}
  #shopify-section-{{ section.id }} .testimonials {
    padding-top:    {{ section.settings.padding_top    | default: 80 }}px;
    padding-bottom: {{ section.settings.padding_bottom | default: 80 }}px;
    {%- if section.settings.background != 'none' -%}
      background: {{ section.settings.background }};
    {%- endif -%}
  }
{% endstyle %}

{{
  'section-testimonials.css'
  | asset_url
  | stylesheet_tag: preload: true, media: 'print', onload: "this.media='all'"
}}

<div class="testimonials" data-section-id="{{ section.id }}">
  <div class="container">

    {%- for block in section.blocks -%}
      {%- case block.type -%}

        {%- comment -%} ── Section heading ─────────────────────────── {%- endcomment -%}
        {%- when 'heading' -%}
          <div class="testimonials__header animate-on-scroll" {{ block.shopify_attributes }}>
            {%- if block.settings.eyebrow != blank -%}
              <p class="testimonials__eyebrow">{{ block.settings.eyebrow | escape }}</p>
            {%- endif -%}
            {%- if block.settings.title != blank -%}
              <h2 class="testimonials__title">{{ block.settings.title }}</h2>
            {%- endif -%}
            {%- if block.settings.subtitle != blank -%}
              <p class="testimonials__subtitle">{{ block.settings.subtitle | escape }}</p>
            {%- endif -%}
          </div>

        {%- comment -%} ── Aggregate rating ────────────────────────── {%- endcomment -%}
        {%- when 'aggregate_rating' -%}
          {%- if block.settings.score != blank -%}
            <div class="testimonials__aggregate animate-on-scroll" {{ block.shopify_attributes }}>
              <span class="testimonials__aggregate-score">{{ block.settings.score }}</span>
              <div class="testimonials__aggregate-meta">
                <div class="testimonials__aggregate-stars" aria-label="{{ block.settings.score }} out of 5">
                  {%- assign score_int = block.settings.score | times: 1 | round -%}
                  {%- for i in (1..5) -%}
                    <svg class="testimonials__aggregate-star" viewBox="0 0 18 18" fill="currentColor" aria-hidden="true">
                      {%- if i <= score_int -%}
                        <path d="M9 1l2.12 4.3 4.74.69-3.43 3.34.81 4.72L9 11.75l-4.24 2.3.81-4.72L2.14 6l4.74-.69z"/>
                      {%- else -%}
                        <path fill="rgba(201,169,110,0.20)" d="M9 1l2.12 4.3 4.74.69-3.43 3.34.81 4.72L9 11.75l-4.24 2.3.81-4.72L2.14 6l4.74-.69z"/>
                      {%- endif -%}
                    </svg>
                  {%- endfor -%}
                </div>
                {%- if block.settings.review_count != blank -%}
                  <span class="testimonials__aggregate-count">
                    {{ block.settings.review_count | escape }} {{ 'sections.product.reviews' | t }}
                  </span>
                {%- endif -%}
              </div>
            </div>
          {%- endif -%}

        {%- comment -%} ── Featured hero review ────────────────────── {%- endcomment -%}
        {%- when 'featured_review' -%}
          {%- if block.settings.body != blank -%}
            <div class="testimonials__hero animate-on-scroll" {{ block.shopify_attributes }}>
              {%- assign stars = block.settings.rating | default: 5 -%}
              <div class="testimonials__hero-stars" aria-label="{{ stars }} out of 5 stars">
                {%- for i in (1..5) -%}
                  <svg class="testimonials__hero-star" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
                    <path d="M8 1l1.76 3.56 3.93.57-2.85 2.77.67 3.92L8 9.9l-3.51 1.85.67-3.92L2.31 5.13l3.93-.57z"/>
                  </svg>
                {%- endfor -%}
              </div>
              <blockquote class="testimonials__hero-body">
                "{{ block.settings.body | escape }}"
              </blockquote>
              <div class="testimonials__hero-author">
                {%- if block.settings.avatar != blank -%}
                  <img
                    src="{{ block.settings.avatar | image_url: width: 88 }}"
                    srcset="{{ block.settings.avatar | image_url: width: 44 }} 1x, {{ block.settings.avatar | image_url: width: 88 }} 2x"
                    alt="{{ block.settings.author | escape }}"
                    class="testimonials__hero-avatar"
                    width="44" height="44"
                    loading="lazy" decoding="async"
                  >
                {%- else -%}
                  <div class="testimonials__hero-avatar" style="background:rgba(201,169,110,0.15);display:flex;align-items:center;justify-content:center;font-family:var(--font-heading);font-size:1.1rem;color:var(--color-accent);">
                    {{ block.settings.author | slice: 0 }}
                  </div>
                {%- endif -%}
                <div class="testimonials__hero-author-info">
                  <p class="testimonials__hero-name">{{ block.settings.author | default: 'Verified Customer' | escape }}</p>
                  <p class="testimonials__hero-meta">
                    {%- if block.settings.verified -%}
                      <svg class="testimonials__verified-icon" viewBox="0 0 12 12" fill="currentColor" aria-hidden="true">
                        <path d="M6 0l1.35 1.95 2.33-.47-.47 2.33L11.16 5 9.21 6.19l.47 2.33-2.33-.47L6 10l-1.35-1.95-2.33.47.47-2.33L.84 5l1.95-1.19-.47-2.33 2.33.47z"/>
                      </svg>
                      {{ 'sections.testimonials.verified_purchase' | t | default: 'Verified' }} •
                    {%- endif -%}
                    {{ block.settings.location | escape }}
                  </p>
                </div>
              </div>
            </div>
          {%- endif -%}

        {%- comment -%} ── Standard review cards ───────────────────── {%- endcomment -%}
        {%- when 'review' -%}
          {%- comment -%}
            Reviews are collected and rendered in a carousel below —
            see the carousel render loop at end of block iteration.
            This block type acts as a data source; we collect them first.
          {%- endcomment -%}

        {%- comment -%} ── Spacer ──────────────────────────────────── {%- endcomment -%}
        {%- when 'spacer' -%}
          <div style="height:{{ block.settings.height | default: 24 }}px;" aria-hidden="true" {{ block.shopify_attributes }}></div>

      {%- endcase -%}
    {%- endfor -%}

    {%- comment -%} ── Collect all review blocks and render carousel ─ {%- endcomment -%}
    {%- assign review_blocks = section.blocks | where: 'type', 'review' -%}
    {%- if review_blocks.size > 0 -%}
      <div class="testimonials__carousel-wrap">

        <div
          class="testimonials__track"
          data-testimonials-track
          role="list"
          aria-label="{{ 'sections.testimonials.reviews_label' | t | default: 'Customer reviews' }}"
        >
          {%- for block in review_blocks -%}
            {%- assign stars = block.settings.rating | default: 5 -%}
            <article
              class="testimonial-card animate-on-scroll"
              role="listitem"
              {{ block.shopify_attributes }}
            >
              {%- comment -%} Stars ──────────────────────────────────── {%- endcomment -%}
              <div class="testimonial-card__stars" aria-label="{{ stars }} out of 5 stars">
                {%- for i in (1..5) -%}
                  <svg
                    class="testimonial-card__star{% if i > stars %} testimonial-card__star--empty{% endif %}"
                    viewBox="0 0 13 13"
                    fill="currentColor"
                    aria-hidden="true"
                  >
                    <path d="M6.5.5l1.58 3.2 3.52.51-2.55 2.48.6 3.51L6.5 8.45l-3.15 1.75.6-3.51L1.4 4.21l3.52-.51z"/>
                  </svg>
                {%- endfor -%}
              </div>

              {%- comment -%} Body ───────────────────────────────────── {%- endcomment -%}
              {%- if block.settings.title != blank -%}
                <p style="font-size:0.875rem;font-weight:700;color:var(--color-text);line-height:1.3;">
                  "{{ block.settings.title | escape }}"
                </p>
              {%- endif -%}
              {%- if block.settings.body != blank -%}
                <p class="testimonial-card__body">{{ block.settings.body | escape }}</p>
              {%- endif -%}

              {%- comment -%} Product link ───────────────────────────── {%- endcomment -%}
              {%- if block.settings.product_name != blank -%}
                {%- assign linked_product = all_products[block.settings.product_handle] -%}
                <a
                  href="{{ linked_product.url | default: '#' }}"
                  class="testimonial-card__product"
                  aria-label="{{ 'sections.testimonials.product_link' | t | default: 'Reviewed product' }}: {{ block.settings.product_name | escape }}"
                >
                  {%- if linked_product.featured_image != blank -%}
                    <img
                      src="{{ linked_product.featured_image | image_url: width: 56 }}"
                      alt="{{ linked_product.featured_image.alt | escape }}"
                      class="testimonial-card__product-img"
                      width="28" height="28"
                      loading="lazy" decoding="async"
                    >
                  {%- endif -%}
                  <span class="testimonial-card__product-name">{{ block.settings.product_name | escape }}</span>
                </a>
              {%- endif -%}

              {%- comment -%} Author ─────────────────────────────────── {%- endcomment -%}
              <div class="testimonial-card__author">
                <div class="testimonial-card__avatar-wrap">
                  {%- if block.settings.avatar != blank -%}
                    <img
                      src="{{ block.settings.avatar | image_url: width: 80 }}"
                      srcset="{{ block.settings.avatar | image_url: width: 40 }} 1x, {{ block.settings.avatar | image_url: width: 80 }} 2x"
                      alt="{{ block.settings.author | default: 'Reviewer' | escape }}"
                      class="testimonial-card__avatar"
                      width="40" height="40"
                      loading="lazy" decoding="async"
                    >
                  {%- else -%}
                    <div class="testimonial-card__avatar" style="background:rgba(201,169,110,0.12);display:flex;align-items:center;justify-content:center;font-size:0.9rem;font-weight:700;color:var(--color-accent);">
                      {{ block.settings.author | default: '?' | slice: 0 | upcase }}
                    </div>
                  {%- endif -%}
                </div>
                <div>
                  <p class="testimonial-card__author-name">{{ block.settings.author | default: 'Verified Customer' | escape }}</p>
                  <p class="testimonial-card__author-meta">
                    {%- if block.settings.verified -%}
                      <svg class="testimonial-card__verified" viewBox="0 0 12 12" fill="#7ecb8a" aria-label="{{ 'sections.testimonials.verified_purchase' | t | default: 'Verified purchase' }}">
                        <path d="M6 0l1.35 1.95 2.33-.47-.47 2.33L11.16 5 9.21 6.19l.47 2.33-2.33-.47L6 10l-1.35-1.95-2.33.47.47-2.33L.84 5l1.95-1.19-.47-2.33 2.33.47z"/>
                      </svg>
                    {%- endif -%}
                    {{ block.settings.location | escape }}
                  </p>
                </div>
                {%- if block.settings.date != blank -%}
                  <time class="testimonial-card__date" datetime="{{ block.settings.date }}">
                    {{ block.settings.date | escape }}
                  </time>
                {%- endif -%}
              </div>

            </article>
          {%- endfor -%}
        </div>{%- comment -%} .testimonials__track {%- endcomment -%}

        {%- comment -%} Prev / Next + dots ──────────────────────────── {%- endcomment -%}
        <div class="testimonials__controls">
          <button type="button" class="testimonials__arrow" data-test-prev disabled aria-label="{{ 'accessibility.previous' | t }}">
            <svg viewBox="0 0 16 16" aria-hidden="true"><path d="M10 4L6 8l4 4" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
          <div class="testimonials__dots" data-test-dots aria-hidden="true">
            {%- for block in review_blocks -%}
              <button type="button" class="testimonials__dot{% if forloop.first %} is-active{% endif %}" data-test-dot="{{ forloop.index0 }}"></button>
            {%- endfor -%}
          </div>
          <button type="button" class="testimonials__arrow" data-test-next aria-label="{{ 'accessibility.next' | t }}">
            <svg viewBox="0 0 16 16" aria-hidden="true"><path d="M6 4l4 4-4 4" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
        </div>
      </div>
    {%- endif -%}

  </div>
</div>

<script>
(function () {
  'use strict';
  const section = document.querySelector('[data-section-id="{{ section.id }}"]');
  if (!section) return;
  const track = section.querySelector('[data-testimonials-track]');
  const prev  = section.querySelector('[data-test-prev]');
  const next  = section.querySelector('[data-test-next]');
  const dots  = section.querySelectorAll('[data-test-dot]');
  if (!track) return;

  const cardW = () => {
    const c = track.firstElementChild;
    if (!c) return 0;
    return c.offsetWidth + parseInt(getComputedStyle(track).gap, 10);
  };
  const update = () => {
    const max = track.scrollWidth - track.clientWidth;
    if (prev) prev.disabled = track.scrollLeft <= 2;
    if (next) next.disabled = track.scrollLeft >= max - 2;
    const idx = Math.round(track.scrollLeft / (cardW() || 1));
    dots.forEach((d, i) => d.classList.toggle('is-active', i === idx));
  };

  prev?.addEventListener('click', () => track.scrollBy({ left: -cardW(), behavior: 'smooth' }));
  next?.addEventListener('click', () => track.scrollBy({ left:  cardW(), behavior: 'smooth' }));
  dots.forEach(d => d.addEventListener('click', () =>
    track.scrollTo({ left: parseInt(d.dataset.testDot, 10) * cardW(), behavior: 'smooth' })
  ));
  track.addEventListener('scroll', window.Lumiere?.throttle?.(update, 80) || update, { passive: true });
  window.addEventListener('resize', window.Lumiere?.debounce?.(update, 200) || update);

  {%- if section.settings.autoplay and section.settings.autoplay_speed > 0 -%}
  let autoTimer = setInterval(() => {
    const max = track.scrollWidth - track.clientWidth;
    if (track.scrollLeft >= max - 2) {
      track.scrollTo({ left: 0, behavior: 'smooth' });
    } else {
      track.scrollBy({ left: cardW(), behavior: 'smooth' });
    }
  }, {{ section.settings.autoplay_speed | times: 1000 }});
  track.addEventListener('pointerenter', () => clearInterval(autoTimer));
  track.addEventListener('pointerleave', () => {
    autoTimer = setInterval(() => {
      const max = track.scrollWidth - track.clientWidth;
      if (track.scrollLeft >= max - 2) track.scrollTo({ left:0, behavior:'smooth' });
      else track.scrollBy({ left: cardW(), behavior:'smooth' });
    }, {{ section.settings.autoplay_speed | times: 1000 }});
  });
  {%- endif -%}

  update();
})();
</script>

{% schema %}
{
  "name": "Testimonials",
  "tag": "section",
  "class": "section-testimonials",
  "settings": [
    {
      "type": "select",
      "id": "background",
      "label": "Background",
      "default": "none",
      "options": [
        { "value": "none",                      "label": "Default" },
        { "value": "var(--color-bg-secondary)", "label": "Secondary" },
        { "value": "rgba(201,169,110,0.03)",    "label": "Warm tint" }
      ]
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Autoplay carousel",
      "default": false
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "label": "Autoplay speed",
      "min": 3, "max": 10, "step": 1, "unit": "s", "default": 5
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0, "max": 160, "step": 8, "unit": "px", "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0, "max": 160, "step": 8, "unit": "px", "default": 80
    }
  ],
  "blocks": [
    {
      "type": "heading",
      "name": "Heading",
      "limit": 1,
      "settings": [
        { "type": "text",     "id": "eyebrow",  "label": "Eyebrow", "default": "Real Results" },
        { "type": "richtext", "id": "title",    "label": "Title",   "default": "<p>What Our Customers <em>Love</em></p>" },
        { "type": "text",     "id": "subtitle", "label": "Subtitle","default": "Over 10,000 five-star reviews and counting." }
      ]
    },
    {
      "type": "aggregate_rating",
      "name": "Overall rating",
      "limit": 1,
      "settings": [
        { "type": "text", "id": "score",        "label": "Score (e.g. 4.9)",   "default": "4.9" },
        { "type": "text", "id": "review_count", "label": "Review count",       "default": "10,482" }
      ]
    },
    {
      "type": "featured_review",
      "name": "Featured review",
      "limit": 1,
      "settings": [
        { "type": "range",       "id": "rating",   "label": "Stars",          "min": 1, "max": 5, "step": 1, "default": 5 },
        { "type": "textarea",    "id": "body",     "label": "Review text",    "default": "I've tried every serum on the market and nothing comes close. My skin has never looked this radiant. The texture, the scent, the results — pure luxury." },
        { "type": "text",        "id": "author",   "label": "Author name",    "default": "Sophie L." },
        { "type": "text",        "id": "location", "label": "Location / label","default": "Paris, France" },
        { "type": "image_picker","id": "avatar",   "label": "Avatar photo" },
        { "type": "checkbox",    "id": "verified", "label": "Verified purchase","default": true }
      ]
    },
    {
      "type": "review",
      "name": "Review card",
      "settings": [
        { "type": "range",       "id": "rating",         "label": "Stars",          "min": 1, "max": 5, "step": 1, "default": 5 },
        { "type": "text",        "id": "title",          "label": "Review headline","default": "Life-changing skincare" },
        { "type": "textarea",    "id": "body",           "label": "Review text",    "default": "I can't believe the difference after just two weeks. My skin feels hydrated, plump, and incredibly smooth. Worth every penny." },
        { "type": "text",        "id": "author",         "label": "Author name",    "default": "Emma R." },
        { "type": "text",        "id": "location",       "label": "Location",       "default": "London, UK" },
        { "type": "text",        "id": "date",           "label": "Date",           "default": "March 2025" },
        { "type": "image_picker","id": "avatar",         "label": "Avatar photo" },
        { "type": "checkbox",    "id": "verified",       "label": "Verified purchase","default": true },
        { "type": "text",        "id": "product_name",   "label": "Reviewed product name" },
        { "type": "text",        "id": "product_handle", "label": "Product handle (for link)", "info": "e.g. radiance-serum" }
      ]
    },
    {
      "type": "spacer",
      "name": "Spacer",
      "settings": [
        { "type": "range", "id": "height", "label": "Height", "min": 8, "max": 80, "step": 4, "unit": "px", "default": 24 }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonials",
      "blocks": [
        { "type": "heading" },
        { "type": "aggregate_rating" },
        { "type": "featured_review" },
        { "type": "review" },
        { "type": "review" },
        { "type": "review" }
      ]
    }
  ]
}
{% endschema %}
