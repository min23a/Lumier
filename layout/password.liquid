<!doctype html>
<html lang="{{ request.locale.iso_code }}" class="no-js">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="theme-color" content="#0d0d0f">

    {%- if settings.favicon != blank -%}
      <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
    {%- endif -%}

    <title>{{ 'general.password.title' | t: shop: shop.name }}</title>

    {%- unless settings.heading_font.system? -%}
      <link rel="preload" as="font" href="{{ settings.heading_font | font_url }}" type="font/woff2" crossorigin>
    {%- endunless -%}

    {%- comment -%} Critical CSS ─────────────────────────────────────────── {%- endcomment -%}
    <style>
      /* Tokens */
      :root {
        --color-bg:      #0d0d0f;
        --color-text:    #f0ede8;
        --color-accent:  #c9a96e;
        --glass-bg:      rgba(255,255,255,0.07);
        --glass-border:  rgba(255,255,255,0.14);
        --glass-blur:    20px;
        --font-heading:  {{ settings.heading_font.family }}, serif;
        --font-body:     {{ settings.body_font.family }}, sans-serif;
        --radius-lg:     20px;
        --radius-full:   9999px;
        --transition-base: 280ms cubic-bezier(0.4,0,0.2,1);
        --container-gutter: 1.5rem;
      }
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      html { font-size: 16px; }
      body {
        min-height:     100dvh;
        display:        flex;
        flex-direction: column;
        align-items:    center;
        justify-content: center;
        padding:        2rem var(--container-gutter);
        background:     var(--color-bg);
        color:          var(--color-text);
        font-family:    var(--font-body);
        -webkit-font-smoothing: antialiased;
        overflow:       hidden;
      }
      img, svg { display: block; max-width: 100%; }
      a { color: var(--color-accent); }

      /* Animated gradient orbs */
      .pw-orb {
        position:      fixed;
        border-radius: 50%;
        filter:        blur(80px);
        opacity:       0.18;
        pointer-events: none;
        z-index:       0;
        animation:     orbFloat 12s ease-in-out infinite alternate;
      }
      .pw-orb--1 {
        width:      500px;
        height:     500px;
        background: radial-gradient(circle, #c9a96e, transparent 70%);
        top:        -200px;
        right:      -100px;
        animation-delay: 0s;
      }
      .pw-orb--2 {
        width:      400px;
        height:     400px;
        background: radial-gradient(circle, #9b6fa0, transparent 70%);
        bottom:     -150px;
        left:       -80px;
        animation-delay: -6s;
      }
      @keyframes orbFloat {
        from { transform: translate(0,0) scale(1); }
        to   { transform: translate(20px, 30px) scale(1.08); }
      }

      /* Card */
      .pw-card {
        position:        relative;
        z-index:         1;
        width:           100%;
        max-width:       440px;
        text-align:      center;
        padding:         clamp(2rem, 6vw, 3.5rem);
        background:      var(--glass-bg);
        border:          1px solid var(--glass-border);
        backdrop-filter: blur(var(--glass-blur));
        -webkit-backdrop-filter: blur(var(--glass-blur));
        border-radius:   var(--radius-lg);
        box-shadow:
          0 8px 32px rgba(0,0,0,0.30),
          inset 0 1px 0 rgba(255,255,255,0.10);
        animation: fadeUp 0.7s cubic-bezier(0.22,1,0.36,1) both;
      }
      @keyframes fadeUp {
        from { opacity: 0; transform: translateY(32px); }
        to   { opacity: 1; transform: translateY(0);     }
      }

      /* Logo / shop name */
      .pw-logo { margin-bottom: 2rem; }
      .pw-logo img { height: 48px; margin: 0 auto; }
      .pw-logo-text {
        font-family:   var(--font-heading);
        font-size:     2rem;
        letter-spacing: -0.03em;
        color:         var(--color-text);
      }

      /* Heading */
      .pw-heading {
        font-family:   var(--font-heading);
        font-size:     clamp(1.5rem, 3vw, 2rem);
        font-weight:   400;
        letter-spacing: -0.02em;
        margin-bottom: 0.75rem;
        line-height:   1.15;
      }
      .pw-heading em { font-style: italic; color: var(--color-accent); }

      /* Body */
      .pw-body {
        font-size:   0.9rem;
        line-height: 1.65;
        color:       rgba(240,237,232,0.65);
        margin-bottom: 2rem;
      }

      /* Form */
      .pw-form { display: flex; flex-direction: column; gap: 0.75rem; }
      .pw-input {
        width:           100%;
        padding:         0.75rem 1.1rem;
        background:      rgba(255,255,255,0.06);
        border:          1px solid rgba(255,255,255,0.12);
        border-radius:   var(--radius-full);
        color:           var(--color-text);
        font-size:       0.9rem;
        font-family:     var(--font-body);
        outline:         none;
        transition:      border-color var(--transition-base), box-shadow var(--transition-base);
        text-align:      center;
      }
      .pw-input::placeholder { color: rgba(240,237,232,0.35); }
      .pw-input:focus {
        border-color: var(--color-accent);
        box-shadow:   0 0 0 3px rgba(201,169,110,0.15);
      }
      .pw-btn {
        width:           100%;
        padding:         0.8rem 1.5rem;
        background:      var(--color-accent);
        color:           #0d0d0f;
        border:          none;
        border-radius:   var(--radius-full);
        font-size:       0.82rem;
        font-weight:     700;
        letter-spacing:  0.08em;
        text-transform:  uppercase;
        cursor:          pointer;
        transition:      opacity var(--transition-base), transform var(--transition-base);
      }
      .pw-btn:hover { opacity: 0.88; transform: translateY(-1px); }

      /* Error */
      .pw-error {
        font-size:    0.8rem;
        color:        #ff7b7b;
        padding:      0.5rem 0.75rem;
        background:   rgba(255,100,100,0.10);
        border-radius: var(--radius-full);
        border:       1px solid rgba(255,100,100,0.20);
      }

      /* Divider */
      .pw-divider {
        display:         flex;
        align-items:     center;
        gap:             var(--spacing-sm, 0.5rem);
        color:           rgba(240,237,232,0.30);
        font-size:       0.75rem;
        letter-spacing:  0.08em;
        margin:          1.5rem 0;
      }
      .pw-divider::before,
      .pw-divider::after {
        content:    '';
        flex:       1;
        height:     1px;
        background: currentColor;
      }

      /* Admin link */
      .pw-admin-link {
        font-size:   0.78rem;
        color:       rgba(240,237,232,0.40);
        text-decoration: none;
        transition:  color var(--transition-base);
      }
      .pw-admin-link:hover { color: rgba(240,237,232,0.75); }

      /* Powered by */
      .pw-powered {
        margin-top:  1.5rem;
        font-size:   0.72rem;
        color:       rgba(240,237,232,0.25);
      }
      .pw-powered a { color: inherit; }
    </style>

    {{ content_for_header }}
  </head>

  <body>
    {%- comment -%} ── Atmospheric orbs ──────────────────────────────── {%- endcomment -%}
    <div class="pw-orb pw-orb--1" aria-hidden="true"></div>
    <div class="pw-orb pw-orb--2" aria-hidden="true"></div>

    {%- comment -%} ── Password card ─────────────────────────────────── {%- endcomment -%}
    <div class="pw-card" role="main">

      {%- comment -%} Logo ─────────────────────────────────────────── {%- endcomment -%}
      <div class="pw-logo">
        {%- if settings.logo != blank -%}
          <img
            src="{{ settings.logo | image_url: height: 96 }}"
            alt="{{ shop.name }}"
            height="48"
            loading="eager"
          >
        {%- else -%}
          <span class="pw-logo-text">{{ shop.name }}</span>
        {%- endif -%}
      </div>

      {%- comment -%} Heading ──────────────────────────────────────── {%- endcomment -%}
      <h1 class="pw-heading">
        {{ 'general.password.heading_html' | t | default: 'Opening <em>Soon</em>' }}
      </h1>
      <p class="pw-body">
        {{ 'general.password.subheading' | t | default: 'We\'re putting the finishing touches on our new collection. Enter the password to get an exclusive preview.' }}
      </p>

      {%- comment -%} Password form ───────────────────────────────── {%- endcomment -%}
      {% form 'storefront_password', class: 'pw-form' %}
        {%- if form.errors -%}
          <p class="pw-error" role="alert">
            {{ 'general.password.wrong_password' | t | default: 'That password is incorrect. Please try again.' }}
          </p>
        {%- endif -%}

        <label for="Password" class="visually-hidden">
          {{ 'general.password.login_form_password_label' | t }}
        </label>
        <input
          type="password"
          name="password"
          id="Password"
          class="pw-input"
          placeholder="{{ 'general.password.login_form_password_placeholder' | t }}"
          autocomplete="current-password"
          required
        >
        <button type="submit" class="pw-btn">
          {{ 'general.password.login_form_submit' | t }}
        </button>
      {% endform %}

      {%- comment -%} Admin link ───────────────────────────────────── {%- endcomment -%}
      <div class="pw-divider">or</div>
      <a href="/admin" class="pw-admin-link">
        {{ 'general.password.admin_link_html' | t | default: 'Are you the store owner? Log in here →' }}
      </a>

    </div>{%- comment -%} .pw-card {%- endcomment -%}

    {%- comment -%} Powered by ──────────────────────────────────────── {%- endcomment -%}
    <p class="pw-powered">
      {{ 'general.password.powered_by_shopify_html' | t: shopify: shop_link }}
    </p>

    <script>document.documentElement.className = document.documentElement.className.replace('no-js','js');</script>
  </body>
</html>
